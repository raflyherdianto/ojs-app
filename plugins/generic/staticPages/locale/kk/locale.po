msgid "plugins.generic.staticPages.pageTitle"
msgstr "Атауы"

msgid "plugins.generic.staticPages.path"
msgstr "Жол"

msgid "plugins.generic.staticPages.staticPages"
msgstr "Статикалық беттер"

msgid "plugins.generic.staticPages.content"
msgstr "Мазмұн"

msgid "plugins.generic.staticPages.editAddContent"
msgstr "Мазмұнды өңдеу/қосу"

msgid "plugins.generic.staticPages.addNewPage"
msgstr "Жаңа бет қосу"

msgid "plugins.generic.staticPages.editStaticPage"
msgstr "Статикалық бетті өңдеу"

msgid "plugins.generic.staticPages.editInstructions"
msgstr "Бет мазмұнын қосу/өңдеу үшін төмендегі форманы пайдаланыңыз."

msgid "plugins.generic.staticPages.duplicatePath"
msgstr "Бұл жол басқа статикалық бет үшін бұрыннан бар."

msgid "plugins.generic.staticPages.pageSaved"
msgstr "Бет сәтті сақталды."

msgid "plugins.generic.staticPages.noneExist"
msgstr "Ешқандай бет жасалмаған"

msgid "plugins.generic.staticPages.pageDeleted"
msgstr "Бет сәтті жойылды."

msgid "plugins.generic.staticPages.addStaticPage"
msgstr "Статикалық бетті қосу"

msgid "plugins.generic.staticPages.displayName"
msgstr "Статикалық беттер плагині"

msgid "plugins.generic.staticPages.noneCreated"
msgstr "Ешқандай статикалық бет жасалмаған."

msgid "plugins.generic.staticPages.pathRegEx"
msgstr ""
"Жол өрісінде тек әріптік-сандық таңбалар, сондай-ақ '.', '/', '-' және '_' "
"болуы керек."

msgid "plugins.generic.staticPages.description"
msgstr "Бұл плагин статикалық мазмұнды басқаруға мүмкіндік береді."

msgid "plugins.generic.staticPages.requirement.tinymce"
msgstr ""
"<p><strong>Мазмұнды қосу/өңдеу үшін TinyMCE плагинін орнату/қосу "
"қажет.</strong></p>"

msgid "plugins.generic.staticPages.settingInstructions"
msgstr ""
"Төмендегі формада сіз жасаған барлық статикалық беттер көрсетілген. Оң "
"жақтағы сілтемелерді пайдаланып беттерді өңдеуге немесе жоюға болады."

msgid "plugins.generic.staticPages.viewInstructions"
msgstr ""
"<p>Бұл бет мына мекенжай бойынша қолжетімді болады: "
"<blockquote>{$pagesPath}</blockquote>...мұндағы %PATH% - жоғарыда енгізілген "
"жол. <strong>Ескерту:</strong> Екі беттің бірдей жолы болуы мүмкін емес. "
"Жүйеге кіріктірілген жолдарды пайдалану маңызды функцияларға кіру "
"мүмкіндігін жоғалтуға әкелуі мүмкін.</p>"
