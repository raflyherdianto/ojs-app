msgstr "Dodatni stilovi/formati citiranja"

msgid "plugins.generic.citationStyleLanguage.settings.citationFormatsDescription"
msgstr "Odaberite dodatne formate koje želite ponuditi svojim čitateljima."

msgid "plugins.generic.citationStyleLanguage.settings.publisherLocation.description"
msgstr ""
"Neki formati citiranja zahtijevaju zemljopisnu lokaciju izdavača, kao što je "
"„London, U.K.”."

msgid "plugins.generic.citationStyleLanguage.settings.citationOptionChooseEditor"
msgstr "Odaberite uloge koje trebaju biti identificirane kao urednici."

msgid "plugins.generic.citationStyleLanguage.download.ris"
msgstr "Endnote/Zotero/Mendeley (RIS)"

msgid "plugins.generic.citationStyleLanguage.settings.citationDownloads"
msgstr "Formati dostupni za preuzimanje"

msgid "plugins.generic.citationStyleLanguage.settings.citationOptionChooseTranslator"
msgstr "Odaberite uloge koje trebaju biti identificirane kao prevoditelji."

msgid "plugins.generic.citationStyleLanguage.settings.citationDownloadsDescription"
msgstr ""
"Odaberite formate za preuzimanje koje želite ponuditi čitateljima. Formati "
"za preuzimanje obično se koriste za uvoz u vanjske programe za upravljanje "
"referencama ibibliografijom, kao što su EndNote ili Zotero."
