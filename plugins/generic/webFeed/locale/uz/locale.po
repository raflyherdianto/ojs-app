msgid "plugins.generic.webfeed.displayName"
msgstr "Veb aloqa Plagini"

msgid "plugins.generic.webfeed.description"
msgstr ""
"Ushbu plagin RSS/Atom veb-sindikatsiya kanallarini ishlab "
"chiqaradi.<br>Plagin shuningdek, ilovangizning yon panelida havolalarni "
"ko'rsatish imkonini beruvchi yon panel blokini ham o'z ichiga oladi"

msgid "plugins.generic.webfeed.settings"
msgstr "Sozlamalar"

msgid "plugins.generic.webfeed.settings.issue"
msgstr "Veb-aloqa havolalarini faqat muammo sahifalarida ko'rsatish."

msgid "plugins.generic.webfeed.settings.homepage"
msgstr "Veb-kanal havolalarini faqat bosh sahifada ko'rsatish."

msgid "plugins.generic.webfeed.settings.all"
msgstr "Barcha ilova sahifalarida veb-tasma havolalarini ko'rsatish."

msgid "plugins.generic.webfeed.settings.currentIssue"
msgstr "Joriy nashr etilgan sondagi elementlarni ko'rsatish."

msgid "plugins.generic.webfeed.settings.recent"
msgstr "Eng so'nggi nashrlarning belgilangan sonini ko'rsatish."

msgid "plugins.generic.webfeed.settings.recentArticles"
msgstr "Ko'rsatiladigan nashrlar soni"

msgid "plugins.generic.webfeed.settings.recentItemsRequired"
msgstr "Yaqinda nashr etilgan elementlar uchun musbat butun sonni kiriting."

msgid "plugins.generic.webfeed.atom.altText"
msgstr "Atom logotipi"

msgid "plugins.generic.webfeed.rss1.altText"
msgstr "RSS1 logotipi"

msgid "plugins.generic.webfeed.rss2.altText"
msgstr "RSS2 logotipi"

msgid "plugins.generic.webfeed.blockTitle"
msgstr "So'nggi nashrlar"

msgid "plugins.generic.webfeed.settings.homepageAndIssues"
msgstr ""
"Veb-tasma havolalarini faqat bosh sahifa va nashr sahifalarida ko'rsatish."

msgid "plugins.generic.webfeed.settings.includeIdentifiers"
msgstr ""
"Tasma xulosasiga identifikatorlarni (ISBN, kalit so'zlar, toifalar va "
"boshqalar) kiritish kerakmi?"
