msgid "plugins.oaiMetadata.jats.description"
msgstr ""
"Strukturerer metadata på en måte som er i overensstemmelse med JATS XML-"
"formatet."

msgid "plugins.oaiMetadata.jats.displayName"
msgstr "JATS metadataformat"

msgid "plugins.oaiMetadataFormats.oaiJats.description"
msgstr ""
"Dette programtillegget leverer metadata til eksterne tjenester i JATS XML-"
"formatet via OAI-PMP grensesnittet. Når det brukes sammen med JATS Template-"
"programtillegg kan det fungere selv om JATS XML-dokumenter ikke har blitt "
"lastet opp i OJS."

msgid "plugins.oaiMetadataFormats.oaiJats.settings"
msgstr "Innstillinger"

msgid "plugins.oaiMetadataFormats.oaiJats.forceJatsTemplate"
msgstr "Ignorer opplastede JATS XML-dokumenter"
